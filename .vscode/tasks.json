{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start Project",
      "type": "shell",
      "command": "pnpm start",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "Build & Preview",
      "type": "shell",
      "command": "pnpm build && pnpm preview",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "Update GitHub Language Colors",
      "type": "shell",
      "command": "pnpm update-colors",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "problemMatcher": []
    }
  ]
}
